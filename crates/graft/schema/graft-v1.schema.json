{
  "$id": "urn:graft:schema:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Graft container configuration v1",
  "description": "Supported Graft TOML workload intent for schema version 1.",
  "type": "object",
  "properties": {
    "config": {
      "description": "Container runtime and platform configuration.",
      "anyOf": [
        {
          "$ref": "#/$defs/Config"
        },
        {
          "type": "null"
        }
      ]
    },
    "dependencies": {
      "description": "Typed relationships to Graft workloads or explicit external units.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/Dependency"
      }
    },
    "deploy": {
      "description": "Required module deployment settings for a complete workload.",
      "type": "object",
      "properties": {
        "activation": {
          "description": "Optional service-manager startup activation.",
          "anyOf": [
            {
              "$ref": "#/$defs/DeployActivation"
            },
            {
              "type": "null"
            }
          ]
        },
        "enable": {
          "description": "Whether the NixOS / HM module should render this container.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "target": {
          "description": "Required scope to render the Quadlet unit in.",
          "oneOf": [
            {
              "description": "NixOS system manager and rootful Podman.",
              "type": "string",
              "const": "system"
            },
            {
              "description": "Home Manager user manager; Podman is rootless only for a non-root account.",
              "type": "string",
              "const": "user"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "target"
      ]
    },
    "name": {
      "description": "Container and Podman identity. Keep it equal to the TOML filename stem\nuntil the final unit identity contract is implemented.",
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "version": {
      "description": "Schema version. Must be `1`.",
      "type": "integer",
      "format": "uint32",
      "maximum": 1,
      "minimum": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "version",
    "name",
    "deploy"
  ],
  "$defs": {
    "Config": {
      "description": "All container configuration (`[config]`).",
      "type": "object",
      "properties": {
        "container": {
          "description": "Supported Quadlet container settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/Container"
            },
            {
              "type": "null"
            }
          ]
        },
        "filesystem": {
          "description": "Supported tmpfs, filesystem volume, and CDI device settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/Filesystem"
            },
            {
              "type": "null"
            }
          ]
        },
        "network": {
          "description": "Supported network namespace and published-port settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/Network"
            },
            {
              "type": "null"
            }
          ]
        },
        "runtime": {
          "description": "Runtime packages and process.",
          "anyOf": [
            {
              "$ref": "#/$defs/Runtime"
            },
            {
              "type": "null"
            }
          ]
        },
        "security": {
          "description": "Secure container defaults and explicit typed relaxations.",
          "anyOf": [
            {
              "$ref": "#/$defs/Security"
            },
            {
              "type": "null"
            }
          ]
        },
        "service": {
          "description": "Supported systemd service settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/Service"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "Container": {
      "description": "Container settings (`[config.container]`).",
      "type": "object",
      "properties": {
        "environment": {
          "description": "Environment assignments rendered in sorted key order.",
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "environmentFile": {
          "description": "Ordered literal Quadlet `EnvironmentFile=` paths.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "group": {
          "description": "Literal Quadlet `Group=` value; requires `user` during resolution.",
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "hostname": {
          "description": "Literal Quadlet `HostName=` value.",
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "user": {
          "description": "Literal Quadlet `User=` value.",
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "workingDir": {
          "description": "Existing process working directory inside the container.",
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "Dependency": {
      "description": "One typed workload or external-unit relationship (`[[dependencies]]`).",
      "type": "object",
      "properties": {
        "lifecycle": {
          "description": "Optional stop/restart lifecycle coupling.",
          "anyOf": [
            {
              "$ref": "#/$defs/DependencyLifecycle"
            },
            {
              "type": "null"
            }
          ]
        },
        "ordering": {
          "description": "Optional startup ordering relationship.",
          "anyOf": [
            {
              "$ref": "#/$defs/DependencyOrdering"
            },
            {
              "type": "null"
            }
          ]
        },
        "requirement": {
          "description": "Optional activation and failure requirement.",
          "anyOf": [
            {
              "$ref": "#/$defs/DependencyRequirement"
            },
            {
              "type": "null"
            }
          ]
        },
        "target": {
          "description": "Exactly one typed relationship target.",
          "$ref": "#/$defs/DependencyTarget"
        }
      },
      "additionalProperties": false,
      "required": [
        "target"
      ]
    },
    "DependencyLifecycle": {
      "description": "Stop and restart lifecycle coupling for a dependency.",
      "oneOf": [
        {
          "description": "Propagate target stop and restart operations through `PartOf=`.",
          "type": "string",
          "const": "part-of"
        },
        {
          "description": "Bind active state to the target through `BindsTo=`.",
          "type": "string",
          "const": "bound"
        }
      ]
    },
    "DependencyOrdering": {
      "description": "Ordering relative to a dependency target.",
      "oneOf": [
        {
          "description": "Start after the target's start job completes.",
          "type": "string",
          "const": "after"
        },
        {
          "description": "Start before the target.",
          "type": "string",
          "const": "before"
        }
      ]
    },
    "DependencyRequirement": {
      "description": "Activation and failure coupling for a dependency.",
      "oneOf": [
        {
          "description": "Start the target and couple activation failure through `Requires=`.",
          "type": "string",
          "const": "required"
        },
        {
          "description": "Start the target without coupling activation failure through `Wants=`.",
          "type": "string",
          "const": "optional"
        }
      ]
    },
    "DependencyTarget": {
      "description": "Typed target for a dependency relationship.",
      "anyOf": [
        {
          "description": "Another workload in the explicit Graft source set.",
          "$ref": "#/$defs/WorkloadDependencyTarget"
        },
        {
          "description": "An exact unit in the selected system or user manager.",
          "$ref": "#/$defs/ExternalUnitDependencyTarget"
        }
      ]
    },
    "DeployActivation": {
      "description": "Supported deployment activation intent.",
      "oneOf": [
        {
          "description": "Request the workload during normal target-manager startup.",
          "type": "string",
          "const": "startup"
        }
      ]
    },
    "Device": {
      "description": "A qualified CDI device reference (`[[config.filesystem.devices]]`).",
      "type": "object",
      "properties": {
        "source": {
          "description": "Colon-free CDI qualified name in `vendor/class=device` form.",
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]*[A-Za-z0-9]/[A-Za-z][A-Za-z0-9._-]*[A-Za-z0-9]=[A-Za-z0-9](?:[A-Za-z0-9._-]*[A-Za-z0-9])?$"
        }
      },
      "additionalProperties": false,
      "required": [
        "source"
      ]
    },
    "ExternalUnitDependencyTarget": {
      "description": "External systemd unit dependency target.",
      "type": "object",
      "properties": {
        "externalUnit": {
          "description": "Concrete systemd unit name in the selected manager.",
          "type": "string",
          "maxLength": 255,
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "externalUnit"
      ]
    },
    "Filesystem": {
      "description": "Filesystem configuration (`[config.filesystem]`).",
      "type": "object",
      "properties": {
        "binds": {
          "description": "Ordered non-recursive host bind mounts.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/FilesystemBind"
          }
        },
        "devices": {
          "description": "Ordered qualified CDI device references.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/Device"
          }
        },
        "readOnly": {
          "description": "Make the container root filesystem read-only, or explicitly retain a writable overlay.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "tmpfs": {
          "description": "Ordered typed writable tmpfs mounts.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/FilesystemTmpfs"
          }
        },
        "volumes": {
          "description": "Ordered Podman-managed volume mounts.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/FilesystemVolume"
          }
        }
      },
      "additionalProperties": false
    },
    "FilesystemBind": {
      "description": "A non-recursive host bind (`[[config.filesystem.binds]]`).",
      "type": "object",
      "properties": {
        "readOnly": {
          "description": "Read-only by default; `false` explicitly grants host-write authority.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "source": {
          "description": "Absolute host source path.",
          "type": "string",
          "minLength": 1
        },
        "target": {
          "description": "Absolute container target path.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "source",
        "target"
      ]
    },
    "FilesystemTmpfs": {
      "description": "A writable tmpfs mount (`[[config.filesystem.tmpfs]]`).",
      "type": "object",
      "properties": {
        "mode": {
          "description": "Optional three- or four-digit octal mode no greater than `1777`.",
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[01]?[0-7]{3}$"
        },
        "size": {
          "description": "Optional positive size with an uppercase K, M, G, or T suffix.",
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[1-9][0-9]*[KMGT]?$"
        },
        "target": {
          "description": "Absolute container target path.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "target"
      ]
    },
    "FilesystemVolume": {
      "description": "A Podman-managed volume (`[[config.filesystem.volumes]]`).",
      "type": "object",
      "properties": {
        "name": {
          "description": "Optional literal named-volume resource; absence requests an anonymous volume.",
          "type": [
            "string",
            "null"
          ],
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
        },
        "readOnly": {
          "description": "Named volumes are writable by default and may be narrowed with `true`;\nanonymous volumes are always writable and reject `true`.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "target": {
          "description": "Required absolute container target path.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "target"
      ]
    },
    "Network": {
      "description": "Network configuration (`[config.network]`).",
      "type": "object",
      "properties": {
        "container": {
          "description": "Graft workload whose network namespace should be shared.",
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "mode": {
          "description": "Network namespace intent. Absence preserves Quadlet's default.",
          "anyOf": [
            {
              "$ref": "#/$defs/NetworkMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "publish": {
          "description": "Ordered literal Quadlet `PublishPort=` entries.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "NetworkMode": {
      "description": "Supported network namespace intent.",
      "oneOf": [
        {
          "description": "Create no externally connected IP network for the workload.",
          "type": "string",
          "const": "none"
        },
        {
          "description": "Share another Graft workload's network namespace.",
          "type": "string",
          "const": "container"
        }
      ]
    },
    "Runtime": {
      "description": "Runtime configuration (`[config.runtime]`).",
      "type": "object",
      "properties": {
        "command": {
          "description": "The non-empty process argument vector to run inside the container.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "mode": {
          "description": "Only `\"rootfs-store\"` is supported today.",
          "type": [
            "string",
            "null"
          ],
          "pattern": "^rootfs-store$"
        },
        "packages": {
          "description": "Nix packages realised onto the container PATH.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "Security": {
      "description": "Security settings (`[config.security]`).",
      "type": "object",
      "properties": {
        "addCapabilities": {
          "description": "Ordered canonical capabilities restored after dropping all defaults.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "pattern": "^CAP_[A-Z][A-Z0-9_]*$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dropCapabilities": {
          "description": "Secure drop-all baseline. Omission and explicit `[\"all\"]` are equivalent.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "pattern": "^all$"
          },
          "maxItems": 1,
          "minItems": 1
        },
        "noNewPrivileges": {
          "description": "Prevent processes from gaining privileges, or explicitly relax that baseline.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "Service": {
      "description": "systemd service settings (`[config.service]`).",
      "type": "object",
      "properties": {
        "lifecycle": {
          "description": "Typed workload lifecycle. Defaults to `long-running` when absent.",
          "anyOf": [
            {
              "$ref": "#/$defs/ServiceLifecycle"
            },
            {
              "type": "null"
            }
          ]
        },
        "restart": {
          "description": "Explicit systemd restart policy.",
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(no|on-success|on-failure|on-abnormal|on-watchdog|on-abort|always)$"
        },
        "restartSec": {
          "description": "Literal systemd restart delay.",
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "timeoutStartSec": {
          "description": "Literal systemd start timeout.",
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "timeoutStopSec": {
          "description": "Literal systemd stop timeout.",
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "ServiceLifecycle": {
      "description": "User-facing workload lifecycle.",
      "oneOf": [
        {
          "description": "Continuously available process using Quadlet's notify lifecycle.",
          "type": "string",
          "const": "long-running"
        },
        {
          "description": "Finite, repeatable process that becomes inactive after success.",
          "type": "string",
          "const": "job"
        },
        {
          "description": "Finite process that remains active/exited after success.",
          "type": "string",
          "const": "setup"
        }
      ]
    },
    "WorkloadDependencyTarget": {
      "description": "Graft workload dependency target.",
      "type": "object",
      "properties": {
        "workload": {
          "description": "Safe top-level Graft workload name.",
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        }
      },
      "additionalProperties": false,
      "required": [
        "workload"
      ]
    }
  }
}
